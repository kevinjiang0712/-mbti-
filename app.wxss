/* 全局样式 */
page {
  background-color: #FFF8F0;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
}

/* 通用容器 */
.container {
  min-height: 100vh;
  padding: 40rpx 32rpx;
  box-sizing: border-box;
}

/* 通用按钮样式 */
.btn-primary {
  background: linear-gradient(135deg, #FFD4B8 0%, #FFA87D 100%);
  color: #fff;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 600;
  box-shadow: 0 4rpx 12rpx rgba(255, 168, 125, 0.25);
  border: none;
}

.btn-primary::after {
  border: none;
}

.btn-secondary {
  background: #FFF;
  color: #FFA87D;
  border: 3rpx solid #FFA87D;
  border-radius: 48rpx;
  font-size: 28rpx;
  font-weight: 500;
}

.btn-secondary::after {
  border: none;
}

/* 卡片样式 */
.card {
  background: #FFFFFF;
  border-radius: 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

/* 文字颜色 */
.text-primary {
  color: #4A4A4A;
}

.text-secondary {
  color: #8B8B8B;
}

.text-muted {
  color: #B8B8B8;
}

.text-accent {
  color: #FFA87D;
}
