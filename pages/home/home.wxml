<view class="container mystical-home {{pageReady ? 'ready' : ''}}">
  <!-- 背景层：星空与魔法光晕 -->
  <view class="bg-stars"></view>
  <view class="bg-glow top-glow"></view>
  <view class="bg-glow bottom-glow"></view>

  <!-- 新增：魔法阵星轨背景 -->
  <view class="astrolabe-bg">
    <view class="astrolabe">
      <view class="astro-inner">
        <view class="astro-center"></view>
      </view>
    </view>
  </view>

  <!-- 新增：巨大月相与流星群 (方案C) -->
  <view class="moon"></view>
  <view class="meteor m1"></view>
  <view class="meteor m2"></view>
  <view class="meteor m3"></view>

  <!-- 内容主视觉 -->
  <view class="content-wrapper">
    <!-- 标题与副标题 (严格遵循PRD) -->
    <view class="header-section fade-in-down">
      <view class="headline">猫咪 MBTI 人格测试</view>
      <view class="sub-headline">12个问题测出“人格类型”</view>
    </view>

    <!-- 中心主视觉：参考你的精美塔罗牌画风 -->
    <view class="hero-section fade-in-scale">
      <view class="tarot-card-frame floating-animation">
        <image class="tarot-image" src="cloud://wechat-env-260305-9em2hcd281d948.7765-wechat-env-260305-9em2hcd281d948-1408536075/assets/tarot_cat.png" mode="aspectFill"></image>
        <view class="tarot-card-border"></view>
        <view class="tarot-card-glow"></view>
      </view>
    </view>

    <!-- 底部操作区 (严格遵循PRD) -->
    <view class="action-section fade-in-up">
      <view class="tip-text">按多数情况下表现选择</view>
      <button class="primary-btn mystical-glow-btn" bindtap="startQuiz">
        <text class="btn-text">开始测猫</text>
      </button>
    </view>
  </view>
</view>
