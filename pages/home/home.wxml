<view class="container home-container {{pageReady ? 'ready' : ''}}">
  <!-- 沉浸式动态深海/星空/梦幻背景 -->
  <view class="immersive-bg"></view>
  <view class="ambient-light light-1"></view>
  <view class="ambient-light light-2"></view>
  <view class="ambient-light light-3"></view>

  <!-- 主内容容器（毛玻璃质感） -->
  <view class="glass-content">
    
    <!-- 标题区 -->
    <view class="title-section fade-in-down">
      <text class="main-title">猫咪 MBTI 人格测试</text>
      <text class="subtitle">用 12 个问题，彻底读懂你家猫的内心世界</text>
    </view>

    <!-- 猫咪图片轮播区 -->
    <view class="swiper-section fade-in-scale">
      <swiper
        class="cat-swiper"
        indicator-dots="{{true}}"
        indicator-color="rgba(255, 255, 255, 0.4)"
        indicator-active-color="#FFFFFF"
        autoplay="{{true}}"
        interval="3500"
        duration="600"
        circular="{{true}}"
        bindchange="onSwiperChange"
        previous-margin="30rpx"
        next-margin="30rpx"
      >
        <swiper-item wx:for="{{displayCats}}" wx:key="type">
          <view class="swiper-card glass-panel">
            <image
              class="cat-preview-image floating-cat"
              src="{{item.image}}"
              mode="aspectFit"
              bindlongpress="onImageLongPress"
              data-type="{{item.type}}"
            ></image>
            <view class="cat-type-label">{{item.type}}</view>
          </view>
        </swiper-item>
      </swiper>
    </view>

    <!-- 价值说明区 -->
    <view class="value-card fade-in-up">
      <view class="value-item glass-pill">
        <text class="value-icon">🎯</text>
        <text class="value-text">12题精准</text>
      </view>
      <view class="value-item glass-pill">
        <text class="value-icon">🐱</text>
        <text class="value-text">16种人格</text>
      </view>
      <view class="value-item glass-pill">
        <text class="value-icon">✨</text>
        <text class="value-text">MBTI理论</text>
      </view>
    </view>

    <!-- 开始按钮区 -->
    <view class="action-section fade-in-bounce">
      <view class="tip-section">
        <text class="tip-icon">💡</text>
        <text class="tip-text">请根据猫咪在日常多数情况下的表现进行选择</text>
      </view>
      
      <button class="btn-primary start-btn glow-effect" bindtap="startQuiz">
        <text class="btn-text">立即探索</text>
        <text class="btn-arrow">→</text>
      </button>
    </view>

  </view>
</view>
