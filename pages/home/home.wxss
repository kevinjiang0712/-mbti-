/* pages/home/home.wxss */
.mystical-home {
  position: relative;
  min-height: 100vh;
  width: 100vw;
  background-color: #1A153A; /* 深邃紫夜空背景 */
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

/* ============ 背景魔法特效 ============ */
.bg-stars {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  /* 用 CSS 渐变模拟繁星点点 */
  background-image: 
    radial-gradient(4rpx 4rpx at 40rpx 60rpx, rgba(255,255,255,0.9), transparent),
    radial-gradient(3rpx 3rpx at 150rpx 150rpx, rgba(255,255,255,0.6), transparent),
    radial-gradient(6rpx 6rpx at 300rpx 80rpx, rgba(249, 220, 92, 0.8), transparent), /* 金色星星 */
    radial-gradient(3rpx 3rpx at 50rpx 300rpx, rgba(255,255,255,0.7), transparent),
    radial-gradient(5rpx 5rpx at 250rpx 350rpx, rgba(213, 128, 255, 0.8), transparent); /* 紫色星星 */
  background-repeat: repeat;
  background-size: 400rpx 400rpx;
  animation: star-twinkle 4s infinite alternate;
  z-index: 1;
}

@keyframes star-twinkle {
  0% { opacity: 0.3; transform: scale(1); }
  100% { opacity: 0.8; transform: scale(1.02); }
}

.bg-glow {
  position: absolute;
  border-radius: 50%;
  filter: blur(120rpx);
  z-index: 2;
  opacity: 0.7;
}

.top-glow {
  width: 700rpx; height: 700rpx;
  background: rgba(162, 110, 255, 0.4); /* 暗紫色渐变光 */
  top: -200rpx; left: -150rpx;
}

.bottom-glow {
  width: 800rpx; height: 800rpx;
  background: rgba(255, 128, 213, 0.25); /* 柔和粉玫瑰光 */
  bottom: -300rpx; right: -200rpx;
}

/* ============ 新增：魔法阵星轨背景 ============ */
.astrolabe-bg {
  position: absolute;
  top: 40%;
  left: 50%;
  transform: translate(-50%, -50%); /* 居中偏上，正好托起塔罗牌 */
  width: 750rpx;
  height: 750rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 3; /* 在星星和光晕之上，主内容之下 */
  pointer-events: none;
  opacity: 0.7; /* 适当透明度保证不喧宾夺主 */
}

.astrolabe { 
  position: absolute; width: 100%; height: 100%; 
  border: 4rpx dashed rgba(213, 128, 255, 0.2); 
  border-radius: 50%; display: flex; align-items: center; justify-content: center; 
  animation: spin-right 90s linear infinite; 
}
.astro-inner { 
  position: absolute; width: 75%; height: 75%; 
  border: 2rpx solid rgba(249, 220, 92, 0.15); 
  border-radius: 50%; display: flex; align-items: center; justify-content: center; 
  animation: spin-left 60s linear infinite; 
}
.astro-inner::before { 
  content: ''; position: absolute; width: 100%; height: 100%; 
  border: 2rpx solid rgba(255,255,255,0.08); 
  transform: rotate(45deg); border-radius: 20rpx; 
}
.astro-center { 
  position: absolute; width: 50%; height: 50%; 
  border-radius: 50%; border: 6rpx double rgba(213, 128, 255, 0.3); 
  animation: spin-right 30s linear infinite; 
  box-shadow: 0 0 60rpx rgba(213, 128, 255, 0.15), inset 0 0 40rpx rgba(213, 128, 255, 0.1); 
}

@keyframes spin-right { 100% { transform: rotate(360deg); } }
@keyframes spin-left { 100% { transform: rotate(-360deg); } }

/* ============ 新增：天体与流星群 (方案C) ============ */
.moon { 
  position: absolute; 
  top: -40rpx; right: -40rpx; /* 在右上角安全区域稍外侧透出一弯发光残月 */
  width: 250rpx; height: 250rpx; 
  border-radius: 50%; 
  box-shadow: -40rpx 40rpx 0 0 rgba(249, 220, 92, 0.9), -60rpx 60rpx 80rpx 0 rgba(249, 220, 92, 0.4); 
  transform: rotate(-20deg); 
  opacity: 0.9;
  z-index: 2; /* 位于最底层星星和顶级UI之间 */
  animation: moon-float 8s infinite alternate ease-in-out;
}
@keyframes moon-float { 
  0% { transform: rotate(-20deg) translate(0,0); } 
  100% { transform: rotate(-25deg) translate(-10rpx, 10rpx); } 
}

.meteor { 
  position: absolute; 
  width: 240rpx; height: 2rpx; 
  background: linear-gradient(90deg, rgba(255,255,255,1), transparent); 
  transform: rotate(-45deg); 
  opacity: 0; 
  z-index: 3;
  animation: meteor-fall 8s infinite linear; 
}
/* 分散流星的位置和出现时机 */
.m1 { top: 25%; left: 80%; animation-delay: 1s; }
.m2 { top: 10%; left: 40%; animation-delay: 4.5s; }
.m3 { top: 70%; left: 90%; animation-delay: 2.5s; }

@keyframes meteor-fall { 
  0% { transform: translate(500rpx, -500rpx) rotate(-45deg); opacity: 1; } 
  15% { transform: translate(-500rpx, 500rpx) rotate(-45deg); opacity: 0; } 
  100% { opacity: 0; } 
}

/* ============ 内容主结构 ============ */
.content-wrapper {
  position: relative;
  z-index: 10;
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  padding: 140rpx 40rpx 80rpx; /* 适配全屏导航的最顶端距离 */
  box-sizing: border-box;
}

/* ============ 标题区 ============ */
.header-section {
  text-align: center;
  margin-top: 20rpx;
}

.headline {
  font-size: 60rpx;
  font-weight: 900;
  color: #FFFFFF;
  margin-bottom: 24rpx;
  letter-spacing: 4rpx;
  text-shadow: 0 4rpx 20rpx rgba(213, 128, 255, 0.8), 0 0 10rpx rgba(255, 255, 255, 0.5);
}

.sub-headline {
  font-size: 40rpx;
  color: #E2D4F0;
  line-height: 1.6;
  font-weight: 400;
  text-shadow: 0 2rpx 8rpx rgba(0,0,0,0.5);
}

/* ============ 塔罗牌插画区 ============ */
.hero-section {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
}

.tarot-card-frame {
  width: 580rpx;
  height: 580rpx; /* 完美适配附图一样的正方形卡片 */
  position: relative;
  border-radius: 48rpx;
  box-shadow: 0 40rpx 80rpx rgba(0, 0, 0, 0.6);
  background-color: #2F1E54;
  display: flex;
  align-items: center;
  justify-content: center;
}

.tarot-image {
  width: 100%;
  height: 100%;
  border-radius: 44rpx; /* 略小于边框保证不穿模 */
  z-index: 5;
  background-color: #2F1E54; /* 防止图片未加载时透色 */
}

/* 内层白框，类似原图边线 */
.tarot-card-border {
  position: absolute;
  top: 10rpx; left: 10rpx; right: 10rpx; bottom: 10rpx;
  border-radius: 36rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.5);
  pointer-events: none;
  z-index: 6;
}

/* 外层霓虹叠加发光特效，还原图片质感 */
.tarot-card-glow {
  position: absolute;
  top: -6rpx; left: -6rpx; right: -6rpx; bottom: -6rpx;
  border-radius: 54rpx;
  border: 6rpx solid transparent; /* 边框本体透明，用背景渐变填充 */
  background: linear-gradient(135deg, rgba(230, 160, 255, 0.6), rgba(249, 220, 92, 0.4), rgba(230, 160, 255, 0.6)) border-box;
  -webkit-mask: linear-gradient(#fff 0 0) padding-box, linear-gradient(#fff 0 0);
  -webkit-mask-composite: xor;
  mask-composite: exclude;
  pointer-events: none;
  z-index: 7;
  box-shadow: 0 0 30rpx rgba(213, 128, 255, 0.5), inset 0 0 20rpx rgba(249, 220, 92, 0.3);
}

.floating-animation {
  animation: tarot-float 6s ease-in-out infinite;
}

@keyframes tarot-float {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-24rpx); }
}

/* ============ 底部操作区 ============ */
.action-section {
  width: 100%;
  padding-bottom: env(safe-area-inset-bottom);
  display: flex;
  flex-direction: column;
  align-items: center;
}

.tip-text {
  font-size: 30rpx;
  color: #BDB2D1;
  margin-bottom: 30rpx;
  letter-spacing: 2rpx;
}

.primary-btn {
  width: 520rpx;
  height: 112rpx;
  border-radius: 56rpx; /* 全圆角胶囊 */
  background: linear-gradient(135deg, #B175FF 0%, #D580FF 50%, #FFB6E1 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  overflow: hidden;
  box-shadow: 0 16rpx 40rpx rgba(177, 117, 255, 0.5), inset 0 -6rpx 12rpx rgba(0,0,0,0.1), inset 0 6rpx 12rpx rgba(255,255,255,0.8); /* 顶级果冻手感 */
  border: none;
  transition: all 0.2s ease;
}

.btn-text {
  font-size: 38rpx;
  font-weight: 800;
  color: #FFFFFF;
  letter-spacing: 6rpx;
  text-shadow: 0 4rpx 10rpx rgba(0,0,0,0.2);
  z-index: 2;
}

.btn-stars {
  font-size: 36rpx;
  margin-left: 12rpx;
  z-index: 2;
  animation: pulse-star 2s infinite alternate;
}

@keyframes pulse-star {
  0% { transform: scale(0.9); opacity: 0.8; }
  100% { transform: scale(1.1); opacity: 1; text-shadow: 0 0 12rpx #FFF; }
}

/* 按钮扫光特效 */
.mystical-glow-btn::before {
  content: '';
  position: absolute;
  top: 0; left: -100%;
  width: 50%; height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.6), transparent);
  transform: skewX(-20deg);
  animation: btn-shine 3s infinite;
  z-index: 1;
}

@keyframes btn-shine {
  0% { left: -100%; }
  20% { left: 200%; }
  100% { left: 200%; }
}

.mystical-glow-btn:active {
  transform: scale(0.96);
  box-shadow: 0 8rpx 20rpx rgba(177, 117, 255, 0.6), inset 0 4rpx 12rpx rgba(0,0,0,0.2);
}

/* ============ 进场动画 ============ */
.fade-in-down, .fade-in-scale, .fade-in-up {
  opacity: 0;
  animation: enter-fade 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
}

.fade-in-down { transform: translateY(-40rpx); }
.fade-in-scale { transform: scale(0.92); animation-delay: 0.2s; }
.fade-in-up { transform: translateY(40rpx); animation-delay: 0.4s; }

@keyframes enter-fade {
  to {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
}
