<view class="container quiz-container">
  <!-- 沉浸式动态深海/星空/梦幻背景 -->
  <view class="immersive-bg"></view>
  <view class="ambient-light light-1"></view>
  <view class="ambient-light light-2"></view>
  
  <view class="glass-content">
    <!-- 进度条 -->
    <view class="progress-section">
      <view class="progress-bar glass-bar">
        <view class="progress-fill glow-fill" style="width: {{progress}}%"></view>
      </view>
      <text class="progress-text">{{currentIndex + 1}}/{{totalQuestions}}</text>
    </view>

    <!-- 题目区 -->
    <view class="question-section glass-panel">
      <view class="question-number">Q{{currentIndex + 1}}</view>
      <text class="question-text">{{currentQuestion.question}}</text>
    </view>

    <!-- 选项区 -->
    <view class="options-section">
      <view
        class="option-item glass-item {{selectedOption === 0 ? 'selected glow-border' : ''}}"
        bindtap="selectOption"
        data-index="0"
      >
        <view class="option-label">A</view>
        <text class="option-text">{{currentQuestion.options[0].text}}</text>
        <view class="option-check" wx:if="{{selectedOption === 0}}">✓</view>
      </view>

      <view
        class="option-item glass-item {{selectedOption === 1 ? 'selected glow-border' : ''}}"
        bindtap="selectOption"
        data-index="1"
      >
        <view class="option-label">B</view>
        <text class="option-text">{{currentQuestion.options[1].text}}</text>
        <view class="option-check" wx:if="{{selectedOption === 1}}">✓</view>
      </view>
    </view>

    <!-- 查看结果按钮（仅最后一题显示） -->
    <view class="button-section" wx:if="{{isLastQuestion && selectedOption !== null}}">
      <button class="btn-primary result-btn glow-effect" bindtap="viewResult">
        查看结果
      </button>
    </view>
  </view>
</view>
