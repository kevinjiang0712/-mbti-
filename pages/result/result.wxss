/* pages/result/result.wxss */
.result-container {
  display: flex; flex-direction: column; min-height: 100vh;
  position: relative; overflow: hidden; background-color: #100C2A;
}
/* 星际沉浸背景 */
.immersive-bg {
  position: absolute; top:0; left:0; right:0; bottom:0;
  background: linear-gradient(180deg, #100C2A 0%, #211347 50%, #30205D 100%); z-index: 0;
}
.star-particles {
  position: absolute; top:0; left:0; right:0; bottom:0;
  background-image: radial-gradient(rgba(255,255,255,0.8) 2rpx, transparent 2rpx);
  background-size: 140rpx 140rpx; opacity: 0.5; z-index: 1;
  animation: twinkle 3s infinite alternate;
}
.moon-bg {
  position: absolute; top: -80rpx; right: -80rpx;
  width: 400rpx; height: 400rpx; border-radius: 50%;
  box-shadow: -40rpx 40rpx 0 0 rgba(249, 220, 92, 0.15), -80rpx 80rpx 160rpx 0 rgba(249, 220, 92, 0.25);
  transform: rotate(-20deg); z-index: 1; opacity: 0.8;
}

/* 主内容安全区 */
.glass-content {
  position: relative; z-index: 10; width: 100%; min-height: 100vh; box-sizing: border-box;
  padding: 140rpx 40rpx 60rpx; display: flex; flex-direction: column; align-items: center;
}

/* ============ SSR 顶级闪卡 ============ */
.ssr-card-wrapper {
  width: 640rpx; height: 640rpx; margin-bottom: 60rpx; position: relative;
  perspective: 1500px;
}
.ssr-card {
  width: 100%; height: 100%; border-radius: 44rpx; position: relative;
  background: #100C2A; box-shadow: 0 40rpx 80rpx rgba(0,0,0,0.8), 0 0 50rpx rgba(213, 128, 255, 0.4);
  display: flex; align-items: center; justify-content: center;
  transform-style: preserve-3d; animation: card-float 8s infinite alternate ease-in-out;
}
@keyframes card-float {
  0% { transform: translateY(0) rotateX(2deg) rotateY(-2deg); }
  100% { transform: translateY(-24rpx) rotateX(-2deg) rotateY(2deg); }
}

/* 镭射全息发光边框 */
.ssr-glow-border {
  position: absolute; top: -6rpx; left: -6rpx; right: -6rpx; bottom: -6rpx;
  border-radius: 50rpx;
  background: linear-gradient(135deg, #F9DC5C, #D580FF, #50FFB4, #D580FF, #F9DC5C);
  background-size: 300% 300%;
  -webkit-mask: linear-gradient(#fff 0 0) padding-box, linear-gradient(#fff 0 0);
  -webkit-mask-composite: xor; mask-composite: exclude;
  border: 6rpx solid transparent; z-index: 20; pointer-events: none;
  animation: holo-border 4s linear infinite;
  box-shadow: inset 0 0 30rpx rgba(249, 220, 92, 0.8), 0 0 20rpx rgba(255,255,255,0.5);
}
@keyframes holo-border { 0% { background-position: 0% 50%; } 100% { background-position: 100% 50%; } }

.ssr-image { width: 100%; height: 100%; border-radius: 38rpx; z-index: 5; object-fit: cover; }

/* SSR 左上角浮雕标志 */
.ssr-badge {
  position: absolute; top: 30rpx; left: 30rpx;
  font-size: 48rpx; font-weight: 900; color: #FFF; font-family: 'Times New Roman', serif;
  text-shadow: 0 0 10rpx #FFF, 0 0 30rpx #F9DC5C, 0 0 50rpx #D580FF; z-index: 10;
}

/* ============ 文案排版区 ============ */
.typography-section { width: 100%; text-align: center; margin-bottom: 50rpx; display: flex; flex-direction: column; align-items: center; }
.type-title {
  font-size: 48rpx; font-weight: 900; color: #FFFFFF;
  letter-spacing: 4rpx;
  text-shadow: 0 4rpx 20rpx rgba(213, 128, 255, 0.9), 0 0 10rpx rgba(255,255,255,0.6);
  margin-bottom: 30rpx;
}
/* 魔法水晶标签 */
.tags-section { display: flex; flex-wrap: wrap; justify-content: center; margin-bottom: 36rpx; gap: 20rpx; }
.magic-tag {
  padding: 12rpx 32rpx; background: rgba(255, 255, 255, 0.08); backdrop-filter: blur(10px);
  border: 2rpx solid rgba(255, 255, 255, 0.2); border-radius: 30rpx;
  font-size: 26rpx; color: #E2D4F0; display: flex; align-items: center;
  box-shadow: 0 4rpx 10rpx rgba(0,0,0,0.4);
}
.tag-dot { color: #F9DC5C; font-size: 26rpx; margin-right: 12rpx; }

/* 详细描述 */
.desc-section { padding: 0 40rpx; }
.desc-text { font-size: 28rpx; color: rgba(255,255,255,0.85); line-height: 1.7; text-align: center; text-shadow: 0 2rpx 6rpx rgba(0,0,0,0.6); }

/* ============ 底部操作区 ============ */
.actions-wrapper { width: 100%; display: flex; flex-direction: column; align-items: center; gap: 32rpx; }

/* 按钮行布局 */
.btn-row {
  width: 100%;
  display: flex;
  justify-content: center;
  gap: 24rpx;
  padding: 0 40rpx;
  box-sizing: border-box;
}

/* 主按钮 - 分享好友 */
.primary-btn {
  flex: 1;
  max-width: 320rpx;
  height: 100rpx;
  border-radius: 50rpx;
  background: linear-gradient(135deg, #B175FF 0%, #D580FF 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  box-shadow: 0 12rpx 32rpx rgba(213, 128, 255, 0.5), inset 0 4rpx 8rpx rgba(255,255,255,0.6);
  border: none;
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}
.primary-btn:active {
  transform: scale(0.95);
  box-shadow: 0 8rpx 20rpx rgba(213, 128, 255, 0.4);
}
.primary-btn .btn-icon { font-size: 28rpx; color: #F9DC5C; }
.primary-btn .btn-text { font-size: 30rpx; font-weight: 600; color: #FFF; letter-spacing: 2rpx; }

/* 次按钮 - 保存海报 */
.secondary-btn {
  flex: 1;
  max-width: 320rpx;
  height: 100rpx;
  border-radius: 50rpx;
  background: rgba(255, 255, 255, 0.08);
  backdrop-filter: blur(10px);
  border: 2rpx solid rgba(255, 255, 255, 0.25);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  color: rgba(255, 255, 255, 0.9);
  transition: transform 0.2s ease, border-color 0.2s ease;
}
.secondary-btn:active {
  transform: scale(0.95);
  border-color: #F9DC5C;
}
.secondary-btn .btn-icon { font-size: 28rpx; color: #F9DC5C; }
.secondary-btn .btn-text { font-size: 30rpx; font-weight: 600; letter-spacing: 2rpx; }

/* 返回链接 */
.back-link {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.6);
  text-decoration: underline;
  text-underline-offset: 6rpx;
  padding: 16rpx 32rpx;
}

/* 进场动画 */
.fade-in-up { opacity: 0; animation: fadeUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards; }
.fade-in-scale { opacity: 0; animation: fadeScale 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards; animation-delay: 0.2s; }
.fade-in-up-delayed { opacity: 0; animation: fadeUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards; animation-delay: 0.4s; }
@keyframes fadeUp { from { opacity: 0; transform: translateY(40rpx); } to { opacity: 1; transform: translateY(0); } }
@keyframes fadeScale { from { opacity: 0; transform: scale(0.9); } to { opacity: 1; transform: scale(1); } }

/* ============ 海报 Canvas (离屏) ============ */
.poster-canvas {
  position: fixed;
  left: -9999rpx;
  top: 0;
  width: 375px;
  height: 667px;
}

/* ============ 海报弹窗 ============ */
.poster-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  visibility: hidden;
  transition: opacity 0.3s ease, visibility 0.3s ease;
}
.poster-modal.show {
  opacity: 1;
  visibility: visible;
}

/* 毛玻璃遮罩 */
.poster-modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(26, 26, 46, 0.9);
  backdrop-filter: blur(20px);
}

/* 弹窗内容 */
.poster-modal-content {
  position: relative;
  z-index: 10;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx;
  animation: modalSlideUp 0.4s cubic-bezier(0.16, 1, 0.3, 1);
}
@keyframes modalSlideUp {
  from { opacity: 0; transform: translateY(60rpx) scale(0.95); }
  to { opacity: 1; transform: translateY(0) scale(1); }
}

/* 海报预览区 */
.poster-preview-wrapper {
  width: 560rpx;
  height: 996rpx;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 40rpx 80rpx rgba(0, 0, 0, 0.6), 0 0 40rpx rgba(213, 128, 255, 0.3);
  animation: posterFloat 4s ease-in-out infinite alternate;
}
@keyframes posterFloat {
  from { transform: translateY(0); }
  to { transform: translateY(-16rpx); }
}

.poster-preview {
  width: 100%;
  height: 100%;
}

/* 保存按钮 */
.save-btn {
  margin-top: 48rpx;
  width: 480rpx;
  height: 100rpx;
  border-radius: 50rpx;
  background: linear-gradient(135deg, #B175FF 0%, #D580FF 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  box-shadow: 0 12rpx 32rpx rgba(213, 128, 255, 0.5), inset 0 4rpx 8rpx rgba(255,255,255,0.6);
  border: none;
}
.save-btn:active {
  transform: scale(0.95);
}
.save-btn .btn-icon { font-size: 28rpx; color: #F9DC5C; }
.save-btn .btn-text { font-size: 32rpx; font-weight: 600; color: #FFF; letter-spacing: 2rpx; }

/* 取消按钮 */
.close-btn {
  margin-top: 32rpx;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.6);
  padding: 16rpx 40rpx;
}
