.result-container {
  min-height: 100vh;
  padding: 0;
  position: relative;
  overflow: hidden;
  background-color: #0F172A;
}

/* ============ 沉浸式背景 ============ */
.immersive-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, #1E1B4B 0%, #312E81 50%, #4338CA 100%);
  z-index: 0;
}

.ambient-light {
  position: absolute;
  border-radius: 50%;
  filter: blur(80px);
  z-index: 0;
  opacity: 0.6;
}

.light-1 {
  width: 600rpx;
  height: 600rpx;
  background: rgba(236, 72, 153, 0.4);
  top: 0;
  left: -100rpx;
  animation: pulse 9s infinite alternate ease-in-out;
}

.light-2 {
  width: 500rpx;
  height: 500rpx;
  background: rgba(245, 158, 11, 0.3);
  bottom: 10%;
  right: -50rpx;
  animation: pulse 11s infinite alternate-reverse ease-in-out;
}

@keyframes pulse {
  0% { transform: scale(0.8); opacity: 0.4; }
  100% { transform: scale(1.2); opacity: 0.7; }
}

.glass-content {
  position: relative;
  z-index: 10;
  width: 100%;
  box-sizing: border-box;
  padding: 40rpx 32rpx 80rpx;
  display: flex;
  flex-direction: column;
}

/* 毛玻璃卡片基类 */
.glass-panel {
  background: rgba(255, 255, 255, 0.1);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  border: 1px solid rgba(255, 255, 255, 0.2);
  border-radius: 32rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.15);
  margin-bottom: 24rpx;
}

/* 猫咪图片卡片 */
.image-card {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 40rpx 0;
}

.cat-image.floating-cat {
  width: 80%;
  height: 420rpx;
  display: block;
  animation: float-cat 6s ease-in-out infinite;
  filter: drop-shadow(0 20rpx 30rpx rgba(0,0,0,0.4));
  border-radius: 20rpx;
}

@keyframes float-cat {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-15rpx); }
}

/* 结果信息卡片 */
.result-card {
  padding: 40rpx 32rpx;
  text-align: center;
}

.type-badge {
  display: inline-block;
  background: linear-gradient(135deg, #F43F5E 0%, #FB923C 100%);
  color: #fff;
  font-size: 34rpx;
  font-weight: 800;
  padding: 16rpx 48rpx;
  border-radius: 48rpx;
  margin-bottom: 28rpx;
  letter-spacing: 4rpx;
  box-shadow: 0 4rpx 16rpx rgba(244, 63, 94, 0.4);
}

.result-title {
  display: block;
  font-size: 48rpx;
  font-weight: 800;
  color: #FFFFFF;
  margin-bottom: 36rpx;
  text-shadow: 0 4rpx 8rpx rgba(0,0,0,0.3);
}

/* 标签区 */
.tags-section {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 20rpx;
  margin-bottom: 40rpx;
}

.glass-tag {
  background: rgba(255, 255, 255, 0.15);
  color: #FFFFFF;
  font-size: 26rpx;
  padding: 12rpx 32rpx;
  border-radius: 24rpx;
  border: 1px solid rgba(255, 255, 255, 0.3);
  font-weight: 600;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.1);
}

/* 描述区 */
.glass-desc {
  background: rgba(0, 0, 0, 0.2);
  border-radius: 24rpx;
  padding: 36rpx;
  border: 1px solid rgba(255, 255, 255, 0.1);
}

.desc-text {
  font-size: 30rpx;
  color: rgba(255, 255, 255, 0.9);
  line-height: 1.8;
  text-align: left;
}

/* 按钮区 */
.button-section {
  display: flex;
  gap: 24rpx;
  padding: 0 10rpx;
  margin-top: 20rpx;
  margin-bottom: 20rpx;
}

.retry-btn,
.home-btn {
  flex: 1;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 700;
  border-radius: 48rpx;
}

.glass-btn {
  background: rgba(255, 255, 255, 0.1);
  color: #FFFFFF;
  border: 2px solid rgba(255, 255, 255, 0.4);
  backdrop-filter: blur(10px);
}

.glow-effect {
  background: linear-gradient(135deg, #F43F5E 0%, #FB923C 100%);
  color: #FFFFFF;
  border: 2px solid rgba(255, 255, 255, 0.2);
  box-shadow: 0 8rpx 20rpx rgba(244, 63, 94, 0.4);
}
